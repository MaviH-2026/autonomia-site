{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "lib": ["ES2020"],
    "declaration": true,
    "outDir": "./dist",
    "rootDir": "./",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "bundler",
    "ignoreDeprecations": "6.0",
    "allowJs": true,
    "noEmit": true
  },
  "include": ["core/**/*.js"],
  "exclude": ["node_modules", "dist", "build", ".git", "tests", "development", "scripts", "product", "cli"]
}
